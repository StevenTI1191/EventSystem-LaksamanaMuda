# =====================================================================
#  ENV TEMPLATE — RUMAHWEB SHARED HOSTING (cPanel) — paket Unlimited M
#  Cara pakai:
#    1. Salin file ini menjadi ".env" di server (bukan .env.rumahweb).
#    2. Ganti semua nilai <ISI_...> dengan data asli dari cPanel/Pusher.
#    3. JANGAN commit file .env yang sudah berisi secret.
#  Skema domain (2 subdomain dari laksamanamuda.id):
#    - client.laksamanamuda.id     -> area publik/klien
#    - backstage.laksamanamuda.id  -> area admin/pegawai
#    - cookie login dibagi via SESSION_DOMAIN=.laksamanamuda.id
#  Beda dari .env.production (VPS/Docker):
#    - Tanpa Redis  -> queue/cache/session pakai database
#    - Tanpa Reverb -> broadcasting pakai Pusher (cloud)
#    - DB_HOST=localhost (MySQL cPanel), bukan container "mysql"
# =====================================================================

APP_NAME="Laksamana Muda"
APP_ENV=production
APP_KEY=base64:M3NpzDfGnNJAbIhmi0Ia2XbiE5xkw0bykvlP58TJWEA=
APP_DEBUG=false
APP_URL=https://backstage.laksamanamuda.id
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# Dua subdomain: client (publik) + backstage (admin). Dipakai Route::domain().
APP_DOMAIN=client.laksamanamuda.id
BACKSTAGE_DOMAIN=backstage.laksamanamuda.id

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------------
# DATABASE — MySQL cPanel Rumahweb (username cPanel: lakk5493)
# Nama DB & user selalu berprefiks username cPanel, mis: lakk5493_dblmb
# ---------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=<ISI_lakk5493_namadb>
DB_USERNAME=<ISI_lakk5493_userdb>
DB_PASSWORD=<ISI_PASSWORD_DB>

# ---------------------------------------------------------------------
# SESSION / QUEUE / CACHE — berbasis DATABASE (shared hosting, tanpa Redis)
# Tabel dibuat otomatis oleh migration (sessions, jobs, cache)
# ---------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Awali titik agar cookie dibagi ke semua subdomain (client.* & backstage.*)
SESSION_DOMAIN=.laksamanamuda.id
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------
# BROADCASTING — PUSHER (cloud). Daftar di https://pusher.com (Channels)
# Buat app -> ambil app_id/key/secret. Cluster ap1 = Singapore.
# ---------------------------------------------------------------------
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=<ISI_PUSHER_APP_ID>
PUSHER_APP_KEY=<ISI_PUSHER_APP_KEY>
PUSHER_APP_SECRET=<ISI_PUSHER_APP_SECRET>
PUSHER_APP_CLUSTER=ap1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Vite (frontend) — HARUS diisi SEBELUM "npm run build" di lokal,
# lalu upload folder public/build hasilnya ke server.
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---------------------------------------------------------------------
# MAIL — SMTP (contoh Brevo). Sesuaikan bila pakai email Rumahweb.
# ---------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=<ISI_SMTP_USERNAME>
MAIL_PASSWORD=<ISI_SMTP_PASSWORD>
MAIL_FROM_ADDRESS="noreply@laksamanamuda.id"
MAIL_FROM_NAME="Laksamana Muda"

# ---------------------------------------------------------------------
# GOOGLE OAUTH (Socialite) — samakan redirect URI di Google Console
# Login klien ada di subdomain client.*
# ---------------------------------------------------------------------
GOOGLE_CLIENT_ID=<ISI_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<ISI_GOOGLE_CLIENT_SECRET>
GOOGLE_REDIRECT_URI=https://client.laksamanamuda.id/auth/google/callback
